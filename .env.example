# =============================================================================
# OpenClaw Instagram Agent - Environment Variables
# Copy to .env and fill in real values: cp .env.example .env
# =============================================================================

# -----------------------------------------------------------------------------
# Instagram Credentials
# -----------------------------------------------------------------------------
INSTAGRAM_USERNAME=your_instagram_username
INSTAGRAM_PASSWORD=your_instagram_password
# 2FA TOTP seed (from authenticator app setup QR code, optional)
# IG_2FA_SEED=your_totp_seed_base32

# -----------------------------------------------------------------------------
# Instagram Graph API (optional, for official API access)
# -----------------------------------------------------------------------------
# INSTAGRAM_ACCESS_TOKEN=your_access_token
# INSTAGRAM_APP_SECRET=your_app_secret
# INSTAGRAM_BUSINESS_ACCOUNT_ID=your_business_account_id

# -----------------------------------------------------------------------------
# Target Accounts (comma-separated usernames)
# -----------------------------------------------------------------------------
TARGET_ACCOUNTS_A=influencer1,influencer2,influencer3
TARGET_ACCOUNTS_B=important1,important2
TARGET_ACCOUNTS_C=friend1,friend2

# -----------------------------------------------------------------------------
# Browser Automation (OpenClaw CDP)
# -----------------------------------------------------------------------------
BROWSER_CDP_HOST=127.0.0.1
BROWSER_CDP_PORT=9222

# -----------------------------------------------------------------------------
# Notifications (optional)
# -----------------------------------------------------------------------------
# TELEGRAM_BOT_TOKEN=your_telegram_bot_token
# TELEGRAM_CHAT_ID=your_chat_id

# -----------------------------------------------------------------------------
# Rate Limiting & Safety
# -----------------------------------------------------------------------------
# Max actions per hour (likes, comments, follows combined)
MAX_ACTIONS_PER_HOUR=20
# Minimum delay between actions in seconds (randomized above this)
MIN_ACTION_DELAY_SECONDS=10
# Maximum delay between actions in seconds
MAX_ACTION_DELAY_SECONDS=30
# Hours to wait before retrying API after failure (falls back to browser)
API_RETRY_HOURS=24

# -----------------------------------------------------------------------------
# Inter-Agent Message Queue (IAMQ)
# Connects to the openclaw-inter-agent-message-queue service
# -----------------------------------------------------------------------------
# IAMQ_ENABLED=true
# IAMQ_HTTP_URL=http://127.0.0.1:18790
# IAMQ_AGENT_ID=instagram_agent
# IAMQ_HEARTBEAT_INTERVAL=240
# IAMQ_POLL_INTERVAL=30

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
LOG_DIR=./logs
